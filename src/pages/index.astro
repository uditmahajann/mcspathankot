---
import Layout from "../layouts/Layout.astro";
import ImportantDocuments from "../components/sections/announcementpage/DocumentLinks";
import HomePopup from "../components/elements/Popup";
import AnnouncementHero from "../components/sections/announcementpage/SwimmingHero";
import { BookOpen, FileBadge, ShieldCheck, Scale } from "lucide-react";

const popupData = [
	{
    id: "basketball",
    image: "/Images/Announcements/announcement1.png",
    buttonText: "View Details",
    buttonLink: "/announcement/basketball",
  },
  {
    id: "swimming",
    image: "/Images/Announcements/announcement2.png",
    buttonText: "View Results (Day-1, 2 & 3)",
    buttonLink: "/announcement/swimming",
  },]

const documents = [
    {
		title: "Day 1 Final Results",

		description: "Official Day 1 results of the CBSE NORTH ZONE-II Swimming Championship under 11,14,17,19 (Girls), including event-wise rankings, timings, medal winners, and final standings.",

		file: "/Documents/D1_Results.pdf",

		icon: FileBadge,
	},
	{
		title: "Day 2 Final Results",

		description: "Official Day 2 results of the CBSE NORTH ZONE-II Swimming Championship under 11,14,17,19 (Girls), including event-wise rankings, timings, medal winners, and final standings.",

		file: "/Documents/D2_Results.pdf",

		icon: FileBadge,
	},
	{
		title: "Day 3 Final Results",

		description: "Official Day 3 results of the CBSE NORTH ZONE-II Swimming Championship under 11,14,17,19 (Girls), including event-wise rankings, timings, medal winners, and final standings.",

		file: "/Documents/D3_Results.pdf",

		icon: FileBadge,
	},
	{
		title: "Invitation Letter & Details",

		description: "Official invitation for schools participating in the CBSE NORTH ZONE-II Swimming Championship under 11,14,17,19 (Girls) and important instructions for all the teams/schools participating in the tournament.",

		file: "/Documents/INVITATION-LETTER-SWIMMING.pdf",

		icon: FileBadge,
	},
	// {
	// 	title: "Swimming Events List",

	// 	description: "Complete list of all swimming events, age categories and race schedule details for teams competing in the CBSE NORTH ZONE-II Swimming Championship under 11,14,17,19 (Girls).",

	// 	file: "/Documents/SWIMMING-EVENT-LIST.pdf",

	// 	icon: FileBadge,
	// },

	// {
