];
---

<Layout
	title="MCS Pathankot Announcements & Highlights | Montessori Cambridge School | Top Boarding School in Pathankot, Punjab and North India region."
	description="Never miss an important update from MCS regarding events, admissions, academics, and campus activities."
	pubDate={new Date()}
>
	<main class="w-full">
		<HomePopup popups={popupData} client:load/>
		<AnnouncementHero/>
		<ImportantDocuments
			title="CBSE NORTH ZONE-II Swimming Championship under 11,14,17,19 (Girls) – Final Results (Day-1,2,3)"
			subtitle="We are pleased to announce the Day-1, Day-2 & Day-3 Final Results of the CBSE NORTH ZONE-II Swimming Championship under 11,14,17,19 (Girls). The results include the official standings and performances across all events conducted on Day-1, 2 & 3 of the championship."
			content="Participating schools, coaches, students, and parents are requested to refer to the official results document for detailed event-wise rankings and timings:"
			documents={documents}
		/>
	</main>
</Layout>






